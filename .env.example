# PawNode identity
NODE_ID=beemo-node-1
STREAMER_SLUG=beemo

# Tapo C120 RTSP → go2rtc (see README STEP 1)
# C120 example: rtsp://pawcam:password@192.168.0.100:554/stream1
RTSP_URL=rtsp://USERNAME:PASSWORD@192.168.0.100:554/stream1

# Petlibro cloud — API: https://github.com/jjjonesjr33/petlibro
PETLIBRO_EMAIL=your@email.com
PETLIBRO_PASSWORD=your-password
PETLIBRO_DEVICE_SN=
PETLIBRO_REGION=US
PETLIBRO_TIMEZONE=Asia/Seoul

# Node API
PORT=3000

# Feed API (MVP — Petlibro Cloud)
FEED_COOLDOWN_SECONDS=3600

# Multi-streamer cooldown overrides (optional JSON)
# STREAMERS_JSON={"beemo":{"cooldown_seconds":30},"mochi":{"cooldown_seconds":45}}

# go2rtc (local)
GO2RTC_URL=http://127.0.0.1:1984
GO2RTC_STREAM_NAME=tapo

# Cloudflare Tunnel (see cloudflare/TUNNEL.md)
CLOUDFLARE_TUNNEL_NAME=pawnode-stream
CLOUDFLARE_STREAM_HOST=stream.chonkpaw.com
CLOUDFLARE_API_HOST=api.chonkpaw.com

# Public HLS URL — auto-set by scripts/create-tunnel.ps1
# https://stream.pawdomain.com/api/stream.m3u8?src=tapo
HLS_PUBLIC_URL=
